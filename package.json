{
  "name": "flashvis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Watch real flash filesystems work: FS-to-WASM over an emulated NOR chip.",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "bash build/build-fastffs.sh",
    "build:fastffs": "bash build/build-fastffs.sh",
    "test:fastffs": "node scripts/fastffs-test.mjs",
    "test:integrity": "node scripts/integrity-test.mjs",
    "test:console": "node scripts/console-api-test.mjs",
    "test:domsmoke": "node scripts/dom-smoke.mjs",
    "test": "npm run test:fastffs && npm run test:integrity && npm run test:console && npm run test:domsmoke",
    "ci": "npm run build:fastffs && npm test"
  }
}
